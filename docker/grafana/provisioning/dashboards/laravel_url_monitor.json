{
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "type": "stat",
            "title": "✅ HTTP 200 整体成功率",
            "gridPos": { "h": 5, "w": 12, "x": 0, "y": 0 },
            "id": 1,
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "editorMode": "code",
                    "expr": "sum(rate(laravel_monitor_url_requests_total{name=~\"$project\", status=\"200\"}[5m])) / sum(rate(laravel_monitor_url_requests_total{name=~\"$project\"}[5m])) * 100",
                    "legendFormat": "成功率",
                    "range": true,
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "red", "value": null },
                            { "color": "orange", "value": 95 },
                            { "color": "green", "value": 99 }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "⚠️ 异常请求占比 (非 200)",
            "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
            "id": 2,
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "editorMode": "code",
                    "expr": "sum(rate(laravel_monitor_url_requests_total{name=~\"$project\", status!=\"200\"}[5m])) / sum(rate(laravel_monitor_url_requests_total{name=~\"$project\"}[5m])) * 100",
                    "legendFormat": "错误率",
                    "range": true,
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 1 },
                            { "color": "red", "value": 5 }
                        ]
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "⏱️ 各站点请求延迟趋势 (Latency)",
            "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
            "id": 3,
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "editorMode": "code",
                    "expr": "laravel_monitor_url_request_latency_seconds{name=~\"$project\"}",
                    "legendFormat": "{{name}}",
                    "range": true,
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth"
                    },
                    "unit": "s"
                }
            }
        },
        {
            "type": "bargauge",
            "title": "🔒 SSL 证书健康状态 (剩余天数)",
            "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
            "id": 4,
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "editorMode": "code",
                    "expr": "laravel_monitor_ssl_certificate_expiry_days{name=~\"$project\"}",
                    "legendFormat": "{{name}}",
                    "range": true,
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "天",
                    "min": 0,
                    "max": 365,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "red", "value": null },
                            { "color": "yellow", "value": 30 },
                            { "color": "green", "value": 90 }
                        ]
                    }
                }
            },
            "options": {
                "orientation": "horizontal",
                "displayMode": "lcd"
            }
        }
    ],
    "refresh": "5s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": ["laravel", "monitor"],
    "time": { "from": "now-15m", "to": "now" },
    "timepicker": {},
    "timezone": "browser",
    "title": "Laravel 完美监控大盘 (完全体)",
